userland: $(INIT_ELF) $(SHELL_ELF) $(LD_GJ_ELF) $(LIBCGJ) $(LIBC_SO) \
	$(LIBGJ_SO) $(LIBGJ_GNU) $(SESSIOND_GJ_ELF) $(NETSTACKD_GJ_ELF) \
	$(SSHD_GJ_ELF) $(STORAGED_GJ_ELF) $(VFSD_GJ_ELF)
	@echo "userland: $(INIT_ELF) $(SHELL_ELF) $(LD_GJ_ELF) $(LIBC_SO) $(LIBGJ_SO) $(LIBGJ_GNU) $(SESSIOND_GJ_ELF) $(NETSTACKD_GJ_ELF) $(SSHD_GJ_ELF) $(STORAGED_GJ_ELF) $(VFSD_GJ_ELF)"

$(LIBGJ): $(LIBGJ_OBJS)
	@mkdir -p $(dir $@)
	ar rcs $@ $(LIBGJ_OBJS)

$(BUILD)/user/libgj/src/%.o: user/libgj/src/%.c
	@mkdir -p $(dir $@)
	$(CC) $(USER_CFLAGS) -c -o $@ $<

$(BUILD)/user/libgj/src/%.o: user/libgj/src/%.S
	@mkdir -p $(dir $@)
	$(CC) $(USER_CFLAGS) -c -o $@ $<

$(INIT_ELF): user/init/init.c $(LIBGJ) user/init/user.ld
	@mkdir -p $(dir $@) $(BUILD)/user/init
	$(CC) $(USER_CFLAGS) -c -o $(BUILD)/user/init/init.o user/init/init.c
	$(LD) $(USER_LDFLAGS) -o $@ $(BUILD)/user/init/init.o $(LIBGJ)
	@echo "built $@"

$(SHELL_ELF): user/shell/shell.c $(LIBGJ) user/init/user.ld
	@mkdir -p $(dir $@) $(BUILD)/user/shell
	$(CC) $(USER_CFLAGS) -c -o $(BUILD)/user/shell/shell.o user/shell/shell.c
	$(LD) $(USER_LDFLAGS) -o $@ $(BUILD)/user/shell/shell.o $(LIBGJ)
	@echo "built $@"

shell-gj: $(SHELL_ELF)
	@echo "shell-gj: $(SHELL_ELF)"

# Freestanding dynamic linker scaffold (PT_INTERP target /lib/ld-gj.so.1)
$(LD_GJ_ELF): user/ld-gj/ld_gj.c $(LIBGJ) user/ld-gj/ld-gj.ld
	@mkdir -p $(dir $@) $(BUILD)/user/ld-gj
	$(CC) $(USER_CFLAGS) -c -o $(BUILD)/user/ld-gj/ld_gj.o user/ld-gj/ld_gj.c
	$(LD) -nostdlib -static -T user/ld-gj/ld-gj.ld -z max-page-size=0x1000 \
		-o $@ $(BUILD)/user/ld-gj/ld_gj.o $(LIBGJ)
	# Drop DWARF so INTERP embed / vfs stage stay under 32 KiB bring-up caps
	objcopy --strip-debug $@ 2>/dev/null || true
	@echo "built $@"

ld-gj: $(LD_GJ_ELF)
	@echo "ld-gj: $(LD_GJ_ELF)"

# ---- Clean-room glibc-shaped C library (libcgj → libc.so.6) ----------------
# Not GNU glibc (see docs/GLIBC_COMPAT.md). Dual MIT OR Apache-2.0 only.
# Userspace SSE allowed (-msse2). AES-NI via -maes is optional on per-TU
# target attributes / multi-version paths; keep portable integer fallbacks.
#
# Graph continuum (soft honesty — CGJ_SRCS parent wire only)
# ---------------------------------------------------------
# CREATE-ONLY freestanding pure-C TUs: user/libcgj/src/graph_batchN.c
# land first; parent pastes paths into CGJ_SRCS (this list). High-water
# is the numeric max basename already listed — not hard-coded elsewhere:
#   makefile_max=24400
# Verify: ./scripts/gj-continuum-makefile-snippet.sh --max
# Soft graph only — not bar3, not Deck Top-50 title runs, not product
# score (gj_bar3_ready_15500 / gj_product_score_15500 remain 0 by design).
# Next decade paste (after CREATE-ONLY wave exists on disk):
#   ./scripts/gj-continuum-makefile-snippet.sh --exist-only FROM TO
#   ./scripts/gj-continuum-makefile-snippet.sh --next [N]
# Continuum extension 15401–15450: pre-decade identity-style batches
# (exist ahead of the M=15500 decade bands below).
# Decade M=15700 bands (docs only): identity 15651–15675, fill 15676–15690,
# markers 15691–15700 (ends at graph_batch15700.c below).
# Extension 15601–15650 may land ahead of the decade bands.
CGJ_CFLAGS := -std=c11 -ffreestanding -fno-builtin -fno-stack-protector \
	-mno-red-zone -msse2 \
	-Wall -Wextra -Werror -Iuser/libcgj/include -g -O2
