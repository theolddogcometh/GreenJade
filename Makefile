# Product PE32+ EFI_APPLICATION: SimpleFileSystem load KERNEL.ELF → kmain_uefi.
# PIC shared ELF → objcopy pei-x86-64 (no mingw required).
.PHONY: greenjade.efi
greenjade.efi: $(BUILD)/GreenJade.efi

$(BUILD)/GreenJade.efi: kernel/boot/uefi_stub.c kernel/boot/efi_link.lds scripts/build-efi.sh
	chmod +x scripts/build-efi.sh
	./scripts/build-efi.sh

# Freestanding compile of UEFI loader (not linked into Multiboot ELF).
uefi-stub: $(BUILD)/kernel/boot/uefi_stub.o
	@echo "uefi-stub: $(BUILD)/kernel/boot/uefi_stub.o"

uefi: greenjade.efi
	@echo "uefi: $(BUILD)/GreenJade.efi"

EFI_CFLAGS := -std=c11 -ffreestanding -fno-builtin -fno-stack-protector \
	-fno-pic -fshort-wchar -mno-red-zone -mno-sse -mno-sse2 -mgeneral-regs-only \
	-Wall -Wextra -Ikernel/include -O2 -g

$(BUILD)/kernel/boot/uefi_stub.o: kernel/boot/uefi_stub.c
	@mkdir -p $(dir $@)
	$(CC) $(EFI_CFLAGS) -c -o $@ $<

# ---- Userspace (freestanding; not Multiboot kernel) -----------------------
# Option 1: userspace may use SSE/AES-NI. Kernel/EFI stay -mno-sse (see CFLAGS /
# EFI_CFLAGS). Note: full XMM integrity across IRQ/context switch still needs
# kernel FXSAVE/XSAVE (not enabled yet); host smoke and careful product paths OK.
USER_CFLAGS := -std=c11 -ffreestanding -fno-builtin -fno-stack-protector \
	-fno-pic -mno-red-zone -msse2 \
	-Wall -Wextra -Werror -Iuser/libgj/include -g -O2
USER_LDFLAGS := -nostdlib -static -T user/init/user.ld -z max-page-size=0x1000

LIBGJ_OBJS := \
	$(BUILD)/user/libgj/src/syscall.o \
	$(BUILD)/user/libgj/src/string_u.o
LIBGJ := $(BUILD)/user/libgj.a
INIT_ELF := $(BUILD)/user/init.elf
SHELL_ELF := $(BUILD)/user/shell.elf
LD_GJ_ELF := $(BUILD)/user/ld-gj.so.1

SESSIOND_GJ_ELF := $(BUILD)/user/sessiond.elf
NETSTACKD_GJ_ELF := $(BUILD)/user/netstackd.elf
SSHD_GJ_ELF := $(BUILD)/user/sshd.elf
STORAGED_GJ_ELF := $(BUILD)/user/storaged.elf
VFSD_GJ_ELF := $(BUILD)/user/vfsd.elf
LIBGJ_SO := $(BUILD)/user/libgj-so.so.1
LIBGJ_GNU := $(BUILD)/user/libgj-gnu.so.1

# Product DT_NEEDED SOs (SysV hash + GNU hash) — real ELF, not text stubs
$(LIBGJ_SO): user/libgj-so/libgj_so.c
	@mkdir -p $(dir $@)
	$(CC) -shared -nostdlib -fPIC -std=c11 -ffreestanding -fno-builtin \
		-fno-stack-protector -Wall -Wextra -Werror -O2 \
		-Wl,-soname,libgj-so.so.1 -Wl,--hash-style=sysv \
		-o $@ user/libgj-so/libgj_so.c
	objcopy --strip-debug $@ 2>/dev/null || true
	@echo "built $@ (SysV-hash product SO)"

$(LIBGJ_GNU): user/libgj-gnu/libgj_gnu.c
	@mkdir -p $(dir $@)
	$(CC) -shared -nostdlib -fPIC -std=c11 -ffreestanding -fno-builtin \
		-fno-stack-protector -Wall -Wextra -Werror -O2 \
		-Wl,-soname,libgj-gnu.so.1 -Wl,--hash-style=gnu \
		-o $@ user/libgj-gnu/libgj_gnu.c
	objcopy --strip-debug $@ 2>/dev/null || true
	@echo "built $@ (GNU-hash product SO)"

libgj-so: $(LIBGJ_SO)
	@echo "libgj-so: $(LIBGJ_SO)"

libgj-gnu: $(LIBGJ_GNU)
	@echo "libgj-gnu: $(LIBGJ_GNU)"

vfsd-gj: $(VFSD_GJ_ELF)
	@echo "vfsd-gj: $(VFSD_GJ_ELF)"

$(VFSD_GJ_ELF): user/vfsd/vfsd_gj.c $(LIBGJ) user/init/user.ld
	@mkdir -p $(dir $@) $(BUILD)/user/vfsd
	$(CC) $(USER_CFLAGS) -c -o $(BUILD)/user/vfsd/vfsd_gj.o user/vfsd/vfsd_gj.c
	$(LD) $(USER_LDFLAGS) -o $@ $(BUILD)/user/vfsd/vfsd_gj.o $(LIBGJ)
	@echo "built $@"

sessiond-gj: $(SESSIOND_GJ_ELF)
	@echo "sessiond-gj: $(SESSIOND_GJ_ELF)"

$(SESSIOND_GJ_ELF): user/session/sessiond_gj.c $(LIBGJ) user/init/user.ld
	@mkdir -p $(dir $@) $(BUILD)/user/session
	$(CC) $(USER_CFLAGS) -c -o $(BUILD)/user/session/sessiond_gj.o \
		user/session/sessiond_gj.c
	$(LD) $(USER_LDFLAGS) -o $@ $(BUILD)/user/session/sessiond_gj.o $(LIBGJ)
	@echo "built $@"

netstackd-gj: $(NETSTACKD_GJ_ELF)
	@echo "netstackd-gj: $(NETSTACKD_GJ_ELF)"

$(NETSTACKD_GJ_ELF): user/netstackd/src/netstackd_gj.c $(LIBGJ) user/init/user.ld
	@mkdir -p $(dir $@) $(BUILD)/user/netstackd
	$(CC) $(USER_CFLAGS) -c -o $(BUILD)/user/netstackd/netstackd_gj.o \
		user/netstackd/src/netstackd_gj.c
	$(LD) $(USER_LDFLAGS) -o $@ $(BUILD)/user/netstackd/netstackd_gj.o $(LIBGJ)
	@echo "built $@"

sshd-gj: $(SSHD_GJ_ELF)
	@echo "sshd-gj: $(SSHD_GJ_ELF)"

# sshd crypto: integer-only (no SSE) — freestanding ring-3 lacks FXSAVE path
SSHD_CFLAGS := $(USER_CFLAGS) -mno-sse -mno-sse2 -mno-mmx -mgeneral-regs-only
$(SSHD_GJ_ELF): user/sshd/src/sshd_gj.c user/sshd/src/ssh_crypto.c $(LIBGJ) \
	user/init/user.ld
	@mkdir -p $(dir $@) $(BUILD)/user/sshd
	$(CC) $(SSHD_CFLAGS) -c -o $(BUILD)/user/sshd/sshd_gj.o \
		user/sshd/src/sshd_gj.c
	$(CC) $(SSHD_CFLAGS) -c -o $(BUILD)/user/sshd/ssh_crypto.o \
		user/sshd/src/ssh_crypto.c
	$(LD) $(USER_LDFLAGS) -o $@ $(BUILD)/user/sshd/sshd_gj.o \
		$(BUILD)/user/sshd/ssh_crypto.o $(LIBGJ)
	@echo "built $@"

storaged-gj: $(STORAGED_GJ_ELF)
	@echo "storaged-gj: $(STORAGED_GJ_ELF)"

$(STORAGED_GJ_ELF): user/storaged/src/storaged_gj.c $(LIBGJ) user/init/user.ld
	@mkdir -p $(dir $@) $(BUILD)/user/storaged
	$(CC) $(USER_CFLAGS) -c -o $(BUILD)/user/storaged/storaged_gj.o \
		user/storaged/src/storaged_gj.c
	$(LD) $(USER_LDFLAGS) -o $@ $(BUILD)/user/storaged/storaged_gj.o $(LIBGJ)
	@echo "built $@"

