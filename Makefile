	user/libcgj/src/graph_batch15300.c \
	user/libcgj/src/rand48.c \
	user/libcgj/src/ether.c \
	user/libcgj/src/sysv_ipc.c \
	user/libcgj/src/graph_batch3.c
# End CGJ_SRCS. Continuum soft high-water: graph_batch15300.c ⇒ makefile_max=15300.
# (Trailing non-batch TUs above: rand48/ether/sysv_ipc + legacy graph_batch3.c.)
CGJ_ASMS := user/libcgj/src/setjmp.S
CGJ_OBJS := $(patsubst user/libcgj/src/%.c,$(BUILD)/user/libcgj/src/%.o,$(CGJ_SRCS)) \
	$(patsubst user/libcgj/src/%.S,$(BUILD)/user/libcgj/src/%.o,$(CGJ_ASMS))
LIBCGJ := $(BUILD)/user/libcgj.a
LIBC_SO := $(BUILD)/user/libc.so.6
LIBC_SO_LINK := $(BUILD)/user/libc.so
CGJ_SMOKE := $(BUILD)/cgj_smoke
CGJ_DYN_SMOKE := $(BUILD)/cgj_dyn_smoke
CGJ_VERMAP := user/libcgj/libc.map

$(BUILD)/user/libcgj/src/%.o: user/libcgj/src/%.c
	@mkdir -p $(dir $@)
	$(CC) $(CGJ_CFLAGS) -fPIC -c -o $@ $<

$(BUILD)/user/libcgj/src/%.o: user/libcgj/src/%.S
	@mkdir -p $(dir $@)
	$(CC) -fPIC -c -o $@ $<

# Prefer setjmp.S only — never build a concurrent setjmp.c (race with subagents)
$(BUILD)/user/libcgj/src/setjmp.o: user/libcgj/src/setjmp.S
	@mkdir -p $(dir $@)
	$(CC) -fPIC -c -o $@ user/libcgj/src/setjmp.S

$(LIBCGJ): $(CGJ_OBJS)
	@mkdir -p $(dir $@)
	ar rcs $@ $(CGJ_OBJS)
	@echo "built $@"

# Shared soname libc.so.6 for DT_NEEDED / rootfs (freestanding, not host glibc)
# GNU symbol versions (GLIBC_2.*) for host-binary bind shape
$(LIBC_SO): $(CGJ_OBJS) $(CGJ_VERMAP)
	@mkdir -p $(dir $@)
	$(CC) -shared -nostdlib -fPIC $(CGJ_CFLAGS) -fPIC \
		-Wl,-soname,libc.so.6 \
		-Wl,--version-script=$(CGJ_VERMAP) \
		-o $@ $(CGJ_OBJS)
	objcopy --strip-debug $@ 2>/dev/null || true
	ln -sfn libc.so.6 $(LIBC_SO_LINK)
	@echo "built $@ (clean-room libcgj soname libc.so.6 + GLIBC_2.* vers)"

# Host freestanding smoke: exercises glibc-shaped API via SYSCALL
$(CGJ_SMOKE): user/libcgj/tests/cgj_smoke.c user/libcgj/src/crt0.c $(LIBCGJ)
	@mkdir -p $(dir $@)
	$(CC) $(CGJ_CFLAGS) -nostdlib -static -o $@ \
		user/libcgj/tests/cgj_smoke.c user/libcgj/src/crt0.c $(LIBCGJ)
	@echo "built $@"

# Dynamic smoke: host dlopen of product libc.so.6 (cannot DT_NEEDED soname
# libc.so.6 under host glibc ld-linux — NPTL private symbols). ld-gj path
# uses the same ELF on GreenJade.
$(CGJ_DYN_SMOKE): user/libcgj/tests/cgj_dyn_smoke.c $(LIBC_SO)
	@mkdir -p $(dir $@)
	$(CC) -std=c11 -Wall -Wextra -O2 -o $@ \
		user/libcgj/tests/cgj_dyn_smoke.c -ldl
	@echo "built $@"

libcgj: $(LIBCGJ) $(LIBC_SO) $(CGJ_SMOKE) $(CGJ_DYN_SMOKE)
	@echo "libcgj: $(LIBCGJ) $(LIBC_SO) $(CGJ_SMOKE) $(CGJ_DYN_SMOKE)"

# Host-side UDX archive for porters (libc available). Use UDX_HOST_LIBC=1.
udx: $(UDX_LIB)

# Runnable host demo: inject PCI → probe → mmio/irq/work → remove
udx-example: $(UDX_EXAMPLE)

$(UDX_LIB): $(UDX_OBJS)
	@mkdir -p $(dir $@)
	ar rcs $@ $(UDX_OBJS)
	@echo "built $@"

$(UDX_EXAMPLE): user/udx/examples/skeleton_pci_driver.c $(UDX_LIB)
	@mkdir -p $(dir $@)
	$(CC) $(UDX_CFLAGS) -DUDX_HOST_LIBC=1 -o $@ \
		user/udx/examples/skeleton_pci_driver.c $(UDX_LIB)
	@echo "built $@  (run: ./$@)"

$(BUILD)/user/udx/%.o: user/udx/%.c
	@mkdir -p $(dir $@)
	$(CC) $(UDX_CFLAGS) -DUDX_HOST_LIBC=1 -c -o $@ $<

# Embed init.elf — build userland first if missing
# Embed objects must rebuild when the product ELF changes (.incbin)
$(BUILD)/kernel/proc/init_embed.o: $(INIT_ELF)
$(BUILD)/kernel/proc/ld_gj_embed.o: $(LD_GJ_ELF)
$(BUILD)/kernel/proc/sessiond_embed.o: $(SESSIOND_GJ_ELF)
$(BUILD)/kernel/proc/netstackd_embed.o: $(NETSTACKD_GJ_ELF)
$(BUILD)/kernel/proc/sshd_embed.o: $(SSHD_GJ_ELF)
$(BUILD)/kernel/proc/storaged_embed.o: $(STORAGED_GJ_ELF)
$(BUILD)/kernel/proc/scsi_mid_embed.o: $(SCSI_MID_GJ_ELF)
$(BUILD)/kernel/proc/hda_client_embed.o: $(HDA_CLIENT_GJ_ELF)
$(BUILD)/kernel/proc/vfsd_embed.o: $(VFSD_GJ_ELF)
$(BUILD)/kernel/proc/shell_embed.o: $(SHELL_ELF)

kernel/proc/init_embed.S: $(INIT_ELF)
kernel/proc/ld_gj_embed.S: $(LD_GJ_ELF)
kernel/proc/sessiond_embed.S: $(SESSIOND_GJ_ELF)
kernel/proc/netstackd_embed.S: $(NETSTACKD_GJ_ELF)
kernel/proc/sshd_embed.S: $(SSHD_GJ_ELF)
kernel/proc/storaged_embed.S: $(STORAGED_GJ_ELF)
kernel/proc/scsi_mid_embed.S: $(SCSI_MID_GJ_ELF)
kernel/proc/hda_client_embed.S: $(HDA_CLIENT_GJ_ELF)
kernel/proc/vfsd_embed.S: $(VFSD_GJ_ELF)
kernel/proc/shell_embed.S: $(SHELL_ELF)

$(KERNEL): $(OBJS) kernel/arch/x86_64/linker.ld $(INIT_ELF)
	@mkdir -p $(dir $@)
	$(LD) $(LDFLAGS) -o $@ $(OBJS)
	@echo "built $@"

$(BUILD)/%.o: %.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c -o $@ $<

$(BUILD)/%.o: %.S
	@mkdir -p $(dir $@)
	$(CC) $(ASFLAGS) -c -o $@ $<

# Auto-generated header dependencies (from -MMD -MP)
-include $(OBJS:.o=.d)

run: $(KERNEL)
	chmod +x scripts/run-qemu.sh
	./scripts/run-qemu.sh $(KERNEL)

license:
	chmod +x scripts/check-license.sh
	./scripts/check-license.sh

clean:
	rm -rf $(BUILD)

# Optional aarch64 product kernel (requires aarch64-linux-gnu-* or AARCH64_CROSS=)
# Shared freestanding C: string, stdio_k, pmm_freelist, sched_coop + arch switch.
AARCH64_CROSS ?= aarch64-linux-gnu-
AARCH64_CC    := $(AARCH64_CROSS)gcc
AARCH64_LD    := $(AARCH64_CROSS)ld
AARCH64_KERNEL := $(BUILD)/greenjade-aarch64.elf
AARCH64_CFLAGS := -std=c11 -ffreestanding -fno-builtin -fno-stack-protector \
	-fno-pic -Wall -Wextra -Werror -Ikernel/include -Ikernel/arch/aarch64 -g -O2 \
	-DGJ_ARCH_AARCH64=1
AARCH64_OBJS := \
	$(BUILD)/aarch64/entry.o \
	$(BUILD)/aarch64/kmain.o \
	$(BUILD)/aarch64/exception.o \
	$(BUILD)/aarch64/exceptions.o \
	$(BUILD)/aarch64/uart_pl011.o \
	$(BUILD)/aarch64/gic.o \
	$(BUILD)/aarch64/timer.o \
	$(BUILD)/aarch64/cpu_info.o \
	$(BUILD)/aarch64/pmm.o \
	$(BUILD)/aarch64/mmu.o \
	$(BUILD)/aarch64/svc.o \
	$(BUILD)/aarch64/virtio_mmio.o \
	$(BUILD)/aarch64/psci.o \
	$(BUILD)/aarch64/switch.o \
	$(BUILD)/aarch64/shared/string.o \
	$(BUILD)/aarch64/shared/stdio_k.o \
	$(BUILD)/aarch64/shared/pmm_freelist.o \
	$(BUILD)/aarch64/shared/sched_coop.o

.PHONY: aarch64 aarch64-smoke
aarch64: $(AARCH64_KERNEL)

aarch64-smoke: $(AARCH64_KERNEL)
	@./scripts/run-aarch64.sh $(AARCH64_KERNEL) | tee $(BUILD)/aarch64-smoke.log; \
	grep -q 'M0 OK' $(BUILD)/aarch64-smoke.log && echo 'aarch64-smoke: PASS' || \
	  (echo 'aarch64-smoke: SKIP or FAIL (see build/aarch64-smoke.log)'; true)

$(AARCH64_KERNEL): $(AARCH64_OBJS) kernel/arch/aarch64/linker.ld
	@mkdir -p $(dir $@)
	$(AARCH64_LD) -nostdlib -static -T kernel/arch/aarch64/linker.ld -o $@ $(AARCH64_OBJS)
	@echo "built $@ (aarch64 product + shared C mm/sched)"

$(BUILD)/aarch64/%.o: kernel/arch/aarch64/%.c
	@mkdir -p $(dir $@)
	$(AARCH64_CC) $(AARCH64_CFLAGS) -c -o $@ $<

$(BUILD)/aarch64/%.o: kernel/arch/aarch64/%.S
	@mkdir -p $(dir $@)
	$(AARCH64_CC) $(AARCH64_CFLAGS) -c -o $@ $<

$(BUILD)/aarch64/shared/string.o: kernel/lib/string.c
	@mkdir -p $(dir $@)
	$(AARCH64_CC) $(AARCH64_CFLAGS) -c -o $@ $<

$(BUILD)/aarch64/shared/stdio_k.o: kernel/lib/stdio_k.c
	@mkdir -p $(dir $@)
	$(AARCH64_CC) $(AARCH64_CFLAGS) -c -o $@ $<

$(BUILD)/aarch64/shared/pmm_freelist.o: kernel/shared/pmm_freelist.c
	@mkdir -p $(dir $@)
	$(AARCH64_CC) $(AARCH64_CFLAGS) -c -o $@ $<

$(BUILD)/aarch64/shared/sched_coop.o: kernel/shared/sched_coop.c
	@mkdir -p $(dir $@)
	$(AARCH64_CC) $(AARCH64_CFLAGS) -c -o $@ $<

