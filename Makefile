.PHONY: all clean run license udx udx-example uefi-stub uefi greenjade.efi ovmf smoke stage-esp stage-rootfs install-img install-usb live-iso hwtest-img install-hwtest-usb hwtest-ssh-setup steam-fetch steam-stage steam-host-prep steam-host-prep-all steam-to-persist steam-to-rootfs userland vulkan-icd sessiond sessiond-gj netstackd netstackd-gj sshd sshd-gj storaged storaged-gj shell-gj ld-gj libcgj libgj-so libgj-gnu vfsd-gj

all: $(KERNEL)

ovmf: greenjade.efi
	chmod +x scripts/run-ovmf.sh
	./scripts/run-ovmf.sh $(BUILD)/GreenJade.efi

# Stage EFI/BOOT + EFI/GREENJADE for real-hw install / USB ESP copy
stage-esp: greenjade.efi $(KERNEL)
	chmod +x scripts/stage-esp.sh
	./scripts/stage-esp.sh $(BUILD)/esp

# Minimal freestanding rootfs tree (sbin/init, bin/sh, etc.)
stage-rootfs: userland
	chmod +x scripts/stage-rootfs.sh
	./scripts/stage-rootfs.sh $(BUILD)/rootfs

# Steam on media — options 2 + 3 (no dpkg on GreenJade). See docs/STEAM_HWTEST.md
# Option 2: pack prebuilt tree into hwtest image at build time
# Option 3: lab-host prep — fetch/extract, copy onto existing image/USB/mount
steam-fetch:
	chmod +x scripts/fetch-steam-bootstrap.sh
	./scripts/fetch-steam-bootstrap.sh

steam-stage:
	chmod +x scripts/stage-steam-tree.sh
	./scripts/stage-steam-tree.sh $(BUILD)/steam-stage
	@echo "steam-stage: pack via hwtest-img (opt2) or steam-host-prep --to-* (opt3)"

# Option 2+3 host workflow: fetch + stage only
steam-host-prep:
	chmod +x scripts/steam-host-prep.sh
	./scripts/steam-host-prep.sh --to-stage

# Option 2 one-shot: fetch + stage + rebuild hwtest-img
steam-host-prep-all:
	chmod +x scripts/steam-host-prep.sh
	./scripts/steam-host-prep.sh --all-img

# Option 3: copy onto plugged-in stick (label GJ-PERSIST) — requires root
steam-to-persist:
	chmod +x scripts/steam-host-prep.sh
	./scripts/steam-host-prep.sh --to-label

# Option 3: copy into build/rootfs (no root)
steam-to-rootfs:
	chmod +x scripts/steam-host-prep.sh
	./scripts/steam-host-prep.sh --to-rootfs

# GPT disk image with ESP (dd to USB or QEMU raw drive)
install-img: stage-esp
	chmod +x scripts/make-install-img.sh
	./scripts/make-install-img.sh $(BUILD)/greenjade-install.img

# Write install image to block device (requires root; wipes device)
# Usage: sudo make install-usb DEV=/dev/sdX
install-usb: install-img
	chmod +x scripts/install-usb.sh
	@test -n "$(DEV)" || (echo "usage: sudo make install-usb DEV=/dev/sdX" >&2; exit 1)
	./scripts/install-usb.sh $(DEV)

# Hybrid live ISO (Multiboot2 + EFI) for QEMU / optical bring-up
# Logs on real USB: use hwtest-img (ESP + GJ-PERSIST), not the ISO alone
live-iso: greenjade.efi $(KERNEL) userland
	chmod +x scripts/make-live-iso.sh
	./scripts/make-live-iso.sh $(BUILD)/greenjade-live.iso

# Dual-partition hardware-test GPT image: ESP + GJ-PERSIST (logs + lab SSH helpers)
hwtest-img: greenjade.efi $(KERNEL) userland
	chmod +x scripts/make-hwtest-img.sh
	./scripts/make-hwtest-img.sh $(BUILD)/greenjade-hwtest.img

# Write hwtest image to USB (requires root; wipes device)
# Usage: sudo make install-hwtest-usb DEV=/dev/sdX
install-hwtest-usb: hwtest-img
	chmod +x scripts/install-hwtest-usb.sh
	@test -n "$(DEV)" || (echo "usage: sudo make install-hwtest-usb DEV=/dev/sdX" >&2; exit 1)
	./scripts/install-hwtest-usb.sh $(DEV)

# Enable OpenSSH on the *lab host* for remote debug (Grok SSHes here, then serial to DUT)
# Usage: sudo make hwtest-ssh-setup
hwtest-ssh-setup:
	chmod +x scripts/hwtest-ssh-setup.sh
	./scripts/hwtest-ssh-setup.sh

smoke:
	chmod +x scripts/smoke-all.sh
	./scripts/smoke-all.sh

# Host ICD: static archive + shared library + JSON + smoke binary
VULKAN_ICD_SRC := user/vulkan_icd/src/vulkan_icd.c user/vulkan_icd/src/gj_vk_icd.c
VULKAN_ICD_OBJS := $(patsubst %.c,$(BUILD)/%.host.o,$(VULKAN_ICD_SRC))
VULKAN_ICD_LIB := $(BUILD)/libgj_vulkan_icd.a
VULKAN_ICD_SO := $(BUILD)/libGreenJade_icd.so
VULKAN_ICD_JSON := $(BUILD)/GreenJade_icd.json
VULKAN_ICD_SMOKE := $(BUILD)/icd_host_smoke

.PHONY: vulkan-icd vulkan-icd-host
vulkan-icd: $(VULKAN_ICD_LIB) $(VULKAN_ICD_SO) $(VULKAN_ICD_JSON)
	@echo "vulkan-icd: $(VULKAN_ICD_LIB) $(VULKAN_ICD_SO) $(VULKAN_ICD_JSON)"

vulkan-icd-host: vulkan-icd $(VULKAN_ICD_SMOKE)
	@echo "vulkan-icd-host: run $(VULKAN_ICD_SMOKE)"

$(BUILD)/user/vulkan_icd/src/%.host.o: user/vulkan_icd/src/%.c
	@mkdir -p $(dir $@)
	$(CC) -std=c11 -Wall -Wextra -O2 -fPIC \
		-Iuser/vulkan_icd/include -Iuser/vulkan_icd/include/vulkan \
		-c -o $@ $<

$(VULKAN_ICD_LIB): $(VULKAN_ICD_OBJS)
	@mkdir -p $(dir $@)
	ar rcs $@ $(VULKAN_ICD_OBJS)
	@echo "built $@"

$(VULKAN_ICD_SO): $(VULKAN_ICD_OBJS)
	@mkdir -p $(dir $@)
	$(CC) -shared -o $@ $(VULKAN_ICD_OBJS)
	@echo "built $@"

$(VULKAN_ICD_JSON): user/vulkan_icd/GreenJade_icd.json
	@mkdir -p $(dir $@)
	cp user/vulkan_icd/GreenJade_icd.json $@
	@echo "built $@"

$(VULKAN_ICD_SMOKE): user/vulkan_icd/tools/icd_host_smoke.c $(VULKAN_ICD_LIB)
	@mkdir -p $(dir $@)
	$(CC) -std=c11 -Wall -Wextra -O2 \
		-Iuser/vulkan_icd/include -Iuser/vulkan_icd/include/vulkan \
		-o $@ user/vulkan_icd/tools/icd_host_smoke.c $(VULKAN_ICD_LIB)
	@echo "built $@"

